{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!docs/api-reference/openapi.json"]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noSvgWithoutTitle": "off"
			},
			"suspicious": {
				"noAssignInExpressions": "warn",
				"noShadowRestrictedNames": "warn",
				"useIterableCallbackReturn": "warn",
				"noImplicitAnyLet": "warn"
			}
		}
	}
}
