# Local development against the shared LocalStack (npm run stack:up).
# Copy to .env (gitignored). Dummy creds satisfy the AWS SDK v3 provider chain.
AWS_ENDPOINT_URL=http://localhost:4566   # global: covers DynamoDB now, S3/SQS/etc. later
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
TURJUMAN_TABLE=Turjuman                  # distinct from TurjumanIntegration used by tests
