{
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "enabledPlugins": {
    "ponytail@ponytail": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/dev-worktree-setup.sh",
            "timeout": 600,
            "statusMessage": "Bootstrapping git worktree (pnpm install + build)…"
          }
        ]
      }
    ]
  }
}
