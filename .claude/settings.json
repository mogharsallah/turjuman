{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/dev-worktree-setup.sh",
						"timeout": 600,
						"statusMessage": "Bootstrapping git worktree (pnpm install + build)…"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/biome-format.sh",
						"statusMessage": "Formatting edited file with Biome…"
					}
				]
			}
		]
	}
}
