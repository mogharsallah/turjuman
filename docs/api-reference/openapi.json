{
  "openapi": "3.1.0",
  "info": {
    "title": "Turjuman API",
    "description": "Deterministic REST API for the Turjuman developer CLI and CI sync.\n\n**Base URL:** your own deployment's `ApiUrl` (printed by `turjuman deploy`); replace the server below with it.\n\n**Auth:** every `/v1/projects` route requires `Authorization: Bearer <api-key>`. The meta endpoints (`/`, `/v1/formats`, `/v1/openapi.json`) are public.",
    "version": "0.2.0"
  },
  "servers": [
    {
      "url": "https://your-turjuman-api.example.com",
      "description": "Your deployed Turjuman API URL (the ApiUrl from `turjuman deploy`)"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Your Turjuman API key"
      }
    },
    "schemas": {
      "ServiceMeta": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "version"
        ]
      },
      "FileFormat": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "extensions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "label",
          "extensions"
        ]
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "orgId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "baseLocale": {
            "type": "string",
            "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
            "description": "Source locale every key is authored in, e.g. \"en\"."
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "orgId",
          "name",
          "slug",
          "baseLocale",
          "createdAt",
          "updatedAt"
        ]
      },
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Human-readable error message."
          },
          "code": {
            "type": "string",
            "enum": [
              "UNAUTHENTICATED",
              "FORBIDDEN",
              "NOT_FOUND",
              "CONFLICT",
              "VALIDATION",
              "INTERNAL"
            ]
          },
          "requestId": {
            "type": "string",
            "description": "Per-request correlation id, echoed in the X-Request-Id header."
          }
        },
        "required": [
          "error",
          "code",
          "requestId"
        ]
      },
      "Locale": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "code": {
            "type": "string",
            "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
            "description": "BCP-47-ish code, e.g. \"fr\", \"es-MX\", \"pt-BR\"."
          },
          "name": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "projectId",
          "code",
          "createdAt"
        ]
      },
      "AddLocaleBody": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "code"
        ]
      },
      "KeyPage": {
        "type": "object",
        "properties": {
          "keys": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TranslationKey"
            }
          },
          "nextCursor": {
            "type": "string",
            "description": "Opaque cursor; pass back as `cursor` for the next page."
          }
        },
        "required": [
          "keys"
        ]
      },
      "TranslationKey": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "namespace": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
            "description": "Logical grouping (file/feature). Defaults to \"default\"."
          },
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "description": {
            "type": "string",
            "description": "Context for translators and the connected LLM."
          },
          "plural": {
            "type": "boolean",
            "description": "When true, values are ICU plural messages."
          },
          "maxLength": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "state": {
            "type": "string",
            "enum": [
              "active",
              "deprecated"
            ],
            "description": "\"active\" when present in the latest source import; \"deprecated\" when absent but retained."
          },
          "lastSeenAt": {
            "type": "string",
            "description": "ISO timestamp of the last import that created, updated, or reactivated this key."
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "projectId",
          "namespace",
          "name",
          "plural",
          "tags",
          "state",
          "createdAt",
          "updatedAt"
        ]
      },
      "ImportKeysResult": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer"
          },
          "updated": {
            "type": "integer"
          },
          "reactivated": {
            "type": "integer"
          },
          "baseValuesSet": {
            "type": "integer"
          },
          "deleted": {
            "type": "integer"
          },
          "deprecated": {
            "type": "integer"
          }
        },
        "required": [
          "created",
          "updated",
          "reactivated",
          "baseValuesSet",
          "deleted",
          "deprecated"
        ]
      },
      "ImportKeysBody": {
        "type": "object",
        "properties": {
          "namespace": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "prune": {
            "type": "boolean"
          },
          "deprecate": {
            "type": "boolean"
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "baseValue": {
                  "type": "string"
                },
                "plural": {
                  "type": "boolean"
                }
              },
              "required": [
                "name"
              ]
            }
          }
        },
        "required": [
          "entries"
        ]
      },
      "Translation": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "localeCode": {
            "type": "string",
            "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
          },
          "namespace": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "keyName": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "value": {
            "type": "string",
            "description": "ICU MessageFormat string (plain string for simple values)."
          },
          "status": {
            "type": "string",
            "enum": [
              "untranslated",
              "translated",
              "approved"
            ]
          },
          "approvedValue": {
            "type": "string",
            "description": "Last approved value — the snapshot delivery ships. Set only on approval (status → \"approved\")."
          },
          "sourceRef": {
            "type": "string",
            "description": "The base value this working `value` was written against; used to derive staleness."
          },
          "origin": {
            "type": "string",
            "enum": [
              "human",
              "llm",
              "tm",
              "mt",
              "import"
            ],
            "description": "How the current `value` was produced. Absent when unknown."
          },
          "updatedBy": {
            "type": "string",
            "description": "userId of the last editor."
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "projectId",
          "localeCode",
          "namespace",
          "keyName",
          "value",
          "status",
          "updatedBy",
          "updatedAt"
        ]
      },
      "BundleEntry": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "namespace": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "plural": {
            "type": "boolean"
          }
        },
        "required": [
          "key",
          "namespace",
          "value",
          "plural"
        ]
      },
      "BulkSetResult": {
        "type": "object",
        "properties": {
          "written": {
            "type": "integer"
          },
          "skipped": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "written",
          "skipped"
        ]
      },
      "ImportTranslationsBody": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "namespace": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
                },
                "value": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "translated",
                    "approved"
                  ]
                }
              },
              "required": [
                "name",
                "value"
              ]
            }
          }
        },
        "required": [
          "locale",
          "entries"
        ]
      },
      "QaReport": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "baseLocale": {
            "type": "string"
          },
          "locales": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Locales actually checked."
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Check ids actually run (enabled ∩ requested)."
          },
          "counts": {
            "$ref": "#/components/schemas/QaReportCounts"
          },
          "findings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QaFinding"
            },
            "description": "Stable-sorted by locale, namespace, keyName, checkId."
          },
          "byLocale": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/QaFinding"
              }
            },
            "description": "The same findings grouped by target locale."
          }
        },
        "required": [
          "projectId",
          "baseLocale",
          "locales",
          "checks",
          "counts",
          "findings",
          "byLocale"
        ]
      },
      "QaReportCounts": {
        "type": "object",
        "properties": {
          "error": {
            "type": "integer"
          },
          "warning": {
            "type": "integer"
          },
          "info": {
            "type": "integer"
          }
        },
        "required": [
          "error",
          "warning",
          "info"
        ]
      },
      "QaFinding": {
        "type": "object",
        "properties": {
          "checkId": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "info"
            ]
          },
          "namespace": {
            "type": "string"
          },
          "keyName": {
            "type": "string"
          },
          "localeCode": {
            "type": "string",
            "description": "The target locale the finding is about."
          },
          "message": {
            "type": "string"
          },
          "value": {
            "type": "string",
            "description": "A short snippet of the offending value."
          }
        },
        "required": [
          "checkId",
          "severity",
          "namespace",
          "keyName",
          "localeCode",
          "message"
        ]
      },
      "RunChecksBody": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "slot": {
            "type": "string",
            "enum": [
              "working",
              "approved"
            ]
          }
        }
      },
      "QaConfig": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "checks": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "info"
                  ]
                }
              }
            },
            "description": "Per-check overrides keyed by check id."
          },
          "ignore": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "checkId": {
                  "type": "string"
                },
                "namespace": {
                  "type": "string"
                },
                "keyName": {
                  "type": "string"
                },
                "locale": {
                  "type": "string"
                }
              }
            },
            "description": "Findings matching any of these rules are dropped from the report."
          },
          "updatedBy": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "projectId",
          "checks",
          "ignore",
          "updatedBy",
          "updatedAt"
        ]
      },
      "QaConfigBody": {
        "type": "object",
        "properties": {
          "checks": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "info"
                  ]
                }
              }
            }
          },
          "ignore": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "checkId": {
                  "type": "string"
                },
                "namespace": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
                },
                "keyName": {
                  "type": "string"
                },
                "locale": {
                  "type": "string",
                  "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
                }
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getIndex",
        "summary": "Service metadata",
        "description": "Returns the service name and version. Public — no auth required.",
        "tags": [
          "Meta"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Service name and version",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceMeta"
                }
              }
            }
          }
        }
      }
    },
    "/v1/formats": {
      "get": {
        "operationId": "getV1Formats",
        "summary": "List supported file formats",
        "description": "The locale file formats the CLI can read/write. Public — no auth required.",
        "tags": [
          "Meta"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Supported formats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "formats": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/FileFormat"
                      }
                    }
                  },
                  "required": [
                    "formats"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects": {
      "get": {
        "operationId": "getV1Projects",
        "summary": "List projects",
        "description": "Projects the authenticated caller can access.",
        "tags": [
          "Projects"
        ],
        "responses": {
          "200": {
            "description": "Projects the caller can access",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "projects": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Project"
                      }
                    }
                  },
                  "required": [
                    "projects"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{id}": {
      "get": {
        "operationId": "getV1ProjectsById",
        "summary": "Get a project",
        "tags": [
          "Projects"
        ],
        "responses": {
          "200": {
            "description": "The project",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ]
      }
    },
    "/v1/projects/{id}/locales": {
      "get": {
        "operationId": "getV1ProjectsByIdLocales",
        "summary": "List a project's locales",
        "tags": [
          "Locales"
        ],
        "responses": {
          "200": {
            "description": "The project's locales",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "locales": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Locale"
                      }
                    }
                  },
                  "required": [
                    "locales"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ]
      },
      "post": {
        "operationId": "postV1ProjectsByIdLocales",
        "summary": "Add a target locale to a project",
        "tags": [
          "Locales"
        ],
        "responses": {
          "201": {
            "description": "The created locale",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Locale"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddLocaleBody"
              }
