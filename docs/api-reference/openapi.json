    "/v1/projects/{id}/bundle": {
      "get": {
        "operationId": "getV1ProjectsByIdBundle",
        "summary": "Export a delivery bundle for a locale",
        "description": "Approved values by default; pass slot=working to ship drafts. Paginate with limit + cursor.",
        "tags": [
          "Translations"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "locale",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Locale code"
          },
          {
            "in": "query",
            "name": "slot",
            "schema": {
              "type": "string",
              "enum": [
                "working"
              ]
            },
            "description": "working = ship drafts instead of approved"
          },
          {
            "in": "query",
            "name": "fallback",
            "schema": {
              "type": "string",
              "enum": [
                "omit"
              ]
            },
            "description": "omit = drop keys with no value instead of source fallback"
          },
          {
            "in": "query",
            "name": "excludeStale",
            "schema": {
              "type": "string",
              "enum": [
                "1"
              ]
            },
            "description": "1 = exclude stale translations"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            },
            "description": "Page size; enables pagination"
          },
          {
            "in": "query",
            "name": "cursor",
            "schema": {
              "type": "string"
            },
            "description": "Opaque cursor from a previous page"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Bundle entries (and nextCursor when paginated)",
