#!/bin/sh
# Keep the committed OpenAPI snapshot (docs/api-reference/openapi.json) in sync
# with the REST API. Runs only when API/core source or the generator is staged,
# so most commits are untouched. The snapshot is regenerated from freshly-built
# output and staged into the commit. Skip with `git commit --no-verify`.
set -e

if git diff --cached --name-only \
  | grep -qE '^(packages/api/src/|packages/core/src/|packages/schema/src/|scripts/gen-openapi\.mjs$)'; then
  echo "[pre-commit] API/core/schema changed — refreshing OpenAPI snapshot..."
  # Build the OpenAPI dependency chain in order. "@turjuman/api..." selects api
  # plus its workspace dependencies (schema → formats → core → api), and pnpm
  # runs them in topological order.
  pnpm --filter "@turjuman/api..." run --silent build >/dev/null
  pnpm run --silent gen:openapi >/dev/null
  git add docs/api-reference/openapi.json
fi
