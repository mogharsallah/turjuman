{
  "name": "@turjuman/api",
  "version": "0.2.0",
  "description": "Turjuman REST API (AWS Lambda) for the developer CLI and CI sync.",
  "license": "MIT",
  "author": "Turjuman contributors",
  "type": "module",
  "main": "./dist/handler.js",
  "types": "./dist/handler.d.ts",
  "exports": {
    ".": "./dist/handler.js",
    "./lambda/handler.mjs": "./lambda/handler.mjs",
    "./lambda/package.json": "./lambda/package.json",
    "./lambda-webhook/webhook.mjs": "./lambda-webhook/webhook.mjs",
    "./lambda-webhook/package.json": "./lambda-webhook/package.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "lambda",
    "lambda-webhook"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mogharsallah/turjuman.git",
    "directory": "packages/api"
  },
  "homepage": "https://github.com/mogharsallah/turjuman#readme",
  "bugs": "https://github.com/mogharsallah/turjuman/issues",
  "keywords": [
    "turjuman",
    "rest-api",
    "i18n",
    "translation",
    "aws-lambda",
    "hono"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-lambda.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist lambda lambda-webhook",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@aws-sdk/util-dynamodb": "^3.700.0",
    "@hono/standard-validator": "^0.2.2",
    "@turjuman/core": "workspace:*",
    "@turjuman/formats": "workspace:*",
    "hono": "^4.12.25",
    "hono-openapi": "^1.3.0",
    "zod": "^3.24.1",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "esbuild": "^0.24.0"
  }
}
