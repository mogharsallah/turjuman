{
  "name": "@turjuman/core",
  "version": "0.2.0",
  "description": "Turjuman server core: the single-table DynamoDB repository and the domain services (built on @turjuman/schema).",
  "license": "MIT",
  "author": "Turjuman contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mogharsallah/turjuman.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/mogharsallah/turjuman#readme",
  "bugs": "https://github.com/mogharsallah/turjuman/issues",
  "keywords": [
    "turjuman",
    "i18n",
    "l10n",
    "localization",
    "translation",
    "dynamodb"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@turjuman/schema": "0.2.0"
  }
}
