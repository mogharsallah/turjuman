{
  "name": "@turjuman/sandbox",
  "version": "0.2.0",
  "description": "Turjuman code-mode sandbox: an isolated QuickJS-WASM engine that runs untrusted TypeScript whose only capability is the @turjuman/sdk operation registry (via an in-process host broker).",
  "license": "MIT",
  "author": "Turjuman contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mogharsallah/turjuman.git",
    "directory": "packages/sandbox"
  },
  "homepage": "https://github.com/mogharsallah/turjuman#readme",
  "bugs": "https://github.com/mogharsallah/turjuman/issues",
  "keywords": [
    "turjuman",
    "sandbox",
    "quickjs",
    "code-execution",
    "mcp"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jitl/quickjs-singlefile-mjs-release-sync": "^0.31.0",
    "@turjuman/core": "workspace:*",
    "@turjuman/sdk": "workspace:*",
    "quickjs-emscripten-core": "^0.31.0",
    "zod": "^3.24.1"
  }
}
