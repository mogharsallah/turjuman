{
  "name": "@turjuman/deploy",
  "version": "0.1.0",
  "description": "Turjuman self-host tooling: deploy, inspect and tear down the AWS stack (CDK programmatic toolkit, no bootstrap).",
  "license": "MIT",
  "author": "Turjuman contributors",
  "type": "module",
  "bin": {
    "turjuman-deploy": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mogharsallah/turjuman.git",
    "directory": "packages/deploy"
  },
  "homepage": "https://github.com/mogharsallah/turjuman#readme",
  "bugs": "https://github.com/mogharsallah/turjuman/issues",
  "keywords": [
    "turjuman",
    "self-hosting",
    "aws",
    "cdk",
    "deploy",
    "i18n",
    "translation"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-cdk/toolkit-lib": "^1.29.0",
    "@aws-sdk/client-cloudformation": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@clack/prompts": "^0.8.2",
    "@turjuman/cli": "0.1.0",
    "@turjuman/core": "0.1.0",
    "adm-zip": "^0.5.16",
    "aws-cdk-lib": "^2.259.0",
    "commander": "^12.1.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.24.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/js-yaml": "^4.0.9"
  }
}
