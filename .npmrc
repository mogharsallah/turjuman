# Dependency cooldown (supply-chain defense).
#
# Refuse to install any package version published less than this many days ago.
# Compromised/malicious npm releases are almost always detected and yanked
# within hours to days (e.g. the 2025 "qix" chalk/debug and "Shai-Hulud" worm
# incidents), so waiting a week before adopting a new version dodges nearly all
# of them at zero ongoing cost.
#
# Unit is DAYS. Requires npm >= 11.10.0 (added Feb 2026); older npm silently
# ignores it. pnpm/yarn call the equivalent "minimumReleaseAge".
min-release-age=7
